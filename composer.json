{
    "name": "pipeosorio1/modules",
    "description": "Laravel Modules",
    "keywords": [
        "modules",
        "laravel",
        "caffeinated"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Shea Lewis",
            "email": "shea.lewis89@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "phpunit/phpunit": "^10.5|^11.0",
        "orchestra/testbench": "^9.0|^10.0",
        "spatie/phpunit-snapshot-assertions": "^5.0"
    },
    "autoload": {
        "files": [
            "src/Support/helpers.php"
        ],
        "psr-4": {
            "Pipeosorio1\\Modules\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pipeosorio1\\Modules\\Tests\\": "tests"
        }
    },
    "suggest": {
        "wikimedia/composer-merge-plugin": "Allows the ability to create and merge composer.json files for your individual modules for module-specific dependency management."
    },
    "extra": {
        "laravel": {
            "providers": [
                "Pipeosorio1\\Modules\\ModulesServiceProvider"
            ],
            "aliases": {
                "Module": "Pipeosorio1\\Modules\\Facades\\Module"
            }
        }
    }
}